{
    "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
    "productName": "rdesq",
    "version": "1.1.5",
    "identifier": "com.rdesq.desktop",
    "build": {
        "frontendDist": "../frontend"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "rdesq",
                "width": 1024,
                "height": 720,
                "minWidth": 600,
                "minHeight": 400,
                "resizable": true,
                "fullscreen": false,
                "visible": true,
                "decorations": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "windows": {
            "nsis": {
                "installMode": "currentUser"
            }
        },
        "linux": {
            "deb": {
                "depends": []
            },
            "appimage": {},
            "rpm": {
                "depends": []
            }
        }
    }
}
