{
    "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
    "productName": "rdesq",
    "version": "1.3.0",
    "identifier": "com.rdesq.desktop",
    "build": {
        "frontendDist": "../frontend"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "rdesq",
                "width": 1024,
                "height": 720,
                "minWidth": 600,
                "minHeight": 400,
                "resizable": true,
                "fullscreen": false,
"visible": false,
"decorations": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "shortDescription": "Remote Desktop Manager",
        "targets": ["deb", "rpm", "msi", "nsis"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/256x256.png",
            "icons/icon.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "windows": {
            "nsis": {
                "installMode": "currentUser"
            }
        },
        "linux": {
            "deb": {
                "depends": [
                    "libwebkit2gtk-4.1-0",
                    "libappindicator3-1",
                    "librsvg2-2",
                    "sshpass"
                ],
                "desktopTemplate": "rdesq.desktop.hbs",
                "postInstallScript": "postinstall.sh",
                "postRemoveScript": "postinstall.sh"
            },
            "appimage": {},
            "rpm": {
                "depends": [
                    "webkit2gtk4.1",
                    "libappindicator-gtk3",
                    "librsvg2",
                    "sshpass"
                ],
                "desktopTemplate": "rdesq.desktop.hbs",
                "postInstallScript": "postinstall.sh",
                "postRemoveScript": "postinstall.sh"
            }
        }
    }
}
